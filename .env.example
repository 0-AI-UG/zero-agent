# Required on first run (or configure via setup wizard at http://localhost:3000/setup)
OPENROUTER_API_KEY=your-key-here

# Optional — these can also be configured at runtime via the admin panel
# OPENROUTER_MODEL=minimax/minimax-m2.7
# IMAGE_MODEL=black-forest-labs/flux.2-klein-4b
# EDIT_APPLY_MODEL=openai/gpt-4o

# Server
# PORT=3001
# DB_PATH=./data/app.db
# S3_BUCKET=zero-agent
# S3_DB_PATH=./data/storage.s3db
# CORS_ORIGIN=http://localhost:3000

# Telegram (optional)
# TELEGRAM_WEBHOOK_SECRET=your-secret
# TELEGRAM_WEBHOOK_BASE_URL=https://your-domain.com
