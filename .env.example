OPENROUTER_API_KEY=your-key-here
BRAVE_SEARCH_API_KEY=your-key-here

# Deployment-level kill switch for the Claude Code / Codex CLI backends.
# Off by default. Flip to `true` after you've (a) provisioned the runner
# image (which bundles the `claude` + `codex` CLIs) and (b) decided to
# expose the BYO-subscription path to users. See docs/cli-subscriptions.md.
# ENABLE_CLI_BACKENDS=false
