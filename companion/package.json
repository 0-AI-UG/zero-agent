{
  "name": "companion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun src/index.ts",
    "build": "bun build --compile src/index.ts --outfile dist/leadsagent-companion",
    "build:macos-arm64": "bun build --compile --target=bun-darwin-arm64 src/index.ts --outfile dist/leadsagent-companion-darwin-arm64",
    "build:macos-x64": "bun build --compile --target=bun-darwin-x64 src/index.ts --outfile dist/leadsagent-companion-darwin-x64",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 src/index.ts --outfile dist/leadsagent-companion-linux-x64",
    "build:windows-x64": "bun build --compile --target=bun-windows-x64 src/index.ts --outfile dist/leadsagent-companion-windows-x64.exe",
    "build:all": "bun run build:macos-arm64 && bun run build:macos-x64 && bun run build:linux-x64 && bun run build:windows-x64"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.10"
  }
}
