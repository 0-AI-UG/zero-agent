    }
  },
  "main": "./dist/sdk.js",
  "types": "./src/sdk/index.ts",
  "scripts": {
    "build": "bun build.ts",
    "dev:cli": "bun src/cli/index.ts"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5"
  }
}
