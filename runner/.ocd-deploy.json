{
  "$schema": 1,
  "$llm": "https://ocd.cero-ai.com/llm.txt",
  "name": "Zero Agent — Runner",
  "description": "Container execution service that manages Docker session containers for agent workloads",
  "suggested_app_name": "zero-runner",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "runner",
    "container_port": 3100
  },
  "extra_volumes": [
    {
      "host_path": "/var/run/docker.sock",
      "container_path": "/var/run/docker.sock"
    }
  ],
  "env": [
    {
      "key": "RUNNER_API_KEY",
      "description": "Shared secret for authenticating requests from the server",
      "required": true,
      "secret": true
    },
    {
      "key": "DEFAULT_IMAGE",
      "description": "Docker image for agent session containers",
      "default": "ghcr.io/0-AI-UG/zero-session:latest"
    },
    {
      "key": "IDLE_TIMEOUT_SECS",
      "description": "Seconds before idle session containers are stopped",
      "default": "600"
    },
    {
      "key": "MAX_CONTAINERS",
      "description": "Maximum number of concurrent session containers",
      "default": "10"
    },
    {
      "key": "LOG_LEVEL",
      "description": "Logging verbosity (debug, info, warn, error)",
      "default": "info"
    }
  ],
  "webhook": {
    "enabled": true,
    "branch": "main",
    "paths": ["runner/"]
  }
}
