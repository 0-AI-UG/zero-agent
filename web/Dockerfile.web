# ---------------------------------------------------------------------------
# Stage 1: Build
# ---------------------------------------------------------------------------
FROM oven/bun:1.3.5 AS builder

WORKDIR /app

COPY web/package.json ./package.json
COPY bun.lock ./
RUN bun install

# Copy all source files needed for the build
COPY web/src/ ./src/
COPY web/styles/ ./styles/
COPY web/build.ts ./
COPY web/tsconfig.json ./
COPY web/bunfig.toml ./
COPY web/components.json ./

RUN bun run build

# ---------------------------------------------------------------------------
# Stage 2: Production
# ---------------------------------------------------------------------------
FROM oven/bun:1.3.5

WORKDIR /app

COPY web/package.json ./package.json
COPY bun.lock ./
RUN bun install

# Copy server entrypoint
COPY web/src/index.ts ./src/index.ts

# Copy pre-built assets into dist/ (served statically in production)
COPY --from=builder /app/dist/ ./dist/

ENV NODE_ENV=production

EXPOSE 3000

CMD ["bun", "src/index.ts"]
