<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Timeline</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { padding: 12px 12px 12px 36px; }
  .tl { position: relative; }
  .tl::before { content: ''; position: absolute; left: -18px; top: 4px; bottom: 4px; width: 1.5px; background: var(--viz-border); }
  .item { position: relative; padding-bottom: 12px; }
  .item:last-child { padding-bottom: 0; }
  .dot { position: absolute; left: -22px; top: 4px; width: 10px; height: 10px; border-radius: 50%; border: 2px solid var(--viz-bg); }
  .card { border: 0.5px solid var(--viz-border); padding: 8px 12px; }
  .date { font-size: 11px; }
  .title { font-size: 13px; font-weight: 500; }
  .desc { font-size: 12px; margin-top: 2px; }
  .tag { display: inline-block; font-size: 10px; padding: 1px 8px; margin-top: 6px; }
</style>
</head>
<body>
<div class="tl" id="tl"></div>
<script>
  const events = [
    { date:'Mar 14, 2026', title:'v2.0 Released', desc:'Major update with new dashboard and reporting.', chart:1, tag:'Release' },
    { date:'Mar 10, 2026', title:'Security Audit', desc:'Passed all compliance checks.', chart:2, tag:'Security' },
    { date:'Mar 5, 2026', title:'Rate Limit Incident', desc:'Traffic spike caused 429 errors for 12 min.', chart:3, tag:'Incident' },
    { date:'Feb 28, 2026', title:'Team Offsite', desc:'Q2 roadmap alignment.', chart:4, tag:'Team' },
    { date:'Feb 20, 2026', title:'Database Migration', desc:'2.4M records migrated, zero downtime.', chart:5, tag:'Infra' },
  ];
  const tl=document.getElementById('tl');
  events.forEach((e,i)=>{
    tl.innerHTML+=`<div class="item" data-viz-delay="${i+1}"><div class="dot viz-chart-${e.chart}" style="background:var(--viz-chart-${e.chart})"></div><div class="card" data-viz="card"><div class="date" data-viz="muted">${e.date}</div><div class="title">${e.title}</div><div class="desc" data-viz="muted">${e.desc}</div><span class="tag viz-chart-${e.chart}" data-viz="badge">${e.tag}</span></div></div>`;
  });
</script>
</body>
</html>
