<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Timeline</title>
<style>
  :root { --bg: #fff; --bg-s: #f8f7f5; --text: #2c2c2a; --text-s: #5f5e5a; --text-t: #888780; --border: rgba(0,0,0,0.12); }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: var(--bg); color: var(--text); padding: 12px 12px 12px 36px; }
  .tl { position: relative; }
  .tl::before { content: ''; position: absolute; left: -18px; top: 4px; bottom: 4px; width: 1.5px; background: var(--border); }
  .item { position: relative; padding-bottom: 12px; }
  .item:last-child { padding-bottom: 0; }
  .dot { position: absolute; left: -22px; top: 4px; width: 10px; height: 10px; border-radius: 50%; border: 2px solid var(--bg); }
  .card { border: 0.5px solid var(--border); border-radius: 8px; padding: 8px 12px; transition: background 0.15s; }
  .card:hover { background: var(--bg-s); }
  .date { font-size: 11px; color: var(--text-t); }
  .title { font-size: 13px; font-weight: 500; }
  .desc { font-size: 12px; color: var(--text-s); margin-top: 2px; }
  .tag { display: inline-block; font-size: 10px; padding: 1px 8px; border-radius: 99px; margin-top: 6px; }
</style>
</head>
<body>
<div class="tl" id="tl"></div>
<script>
  const events = [
    { date:'Mar 14, 2026', title:'v2.0 Released', desc:'Major update with new dashboard and reporting.', color:'#534AB7', tag:'Release' },
    { date:'Mar 10, 2026', title:'Security Audit', desc:'Passed all compliance checks.', color:'#0F6E56', tag:'Security' },
    { date:'Mar 5, 2026', title:'Rate Limit Incident', desc:'Traffic spike caused 429 errors for 12 min.', color:'#E24B4A', tag:'Incident' },
    { date:'Feb 28, 2026', title:'Team Offsite', desc:'Q2 roadmap alignment.', color:'#185FA5', tag:'Team' },
    { date:'Feb 20, 2026', title:'Database Migration', desc:'2.4M records migrated, zero downtime.', color:'#639922', tag:'Infra' },
  ];
  const tl=document.getElementById('tl');
  events.forEach(e=>{
    tl.innerHTML+=`<div class="item"><div class="dot" style="background:${e.color};box-shadow:0 0 0 2px ${e.color}30"></div><div class="card"><div class="date">${e.date}</div><div class="title">${e.title}</div><div class="desc">${e.desc}</div><span class="tag" style="background:${e.color}18;color:${e.color}">${e.tag}</span></div></div>`;
  });
</script>
</body>
</html>
