<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dependency Tree</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: var(--viz-bg); }
  svg { display: block; }
  .nr { stroke-width: 0.5; cursor: pointer; }
  .nl { font-size: 12px; fill: var(--viz-fg); text-anchor: middle; dominant-baseline: central; pointer-events: none; }
  .edge { stroke: var(--viz-muted); stroke-width: 1; fill: none; }
  .tog { fill: var(--viz-card); stroke: var(--viz-border); stroke-width: 0.5; cursor: pointer; }
  .ti { font-size: 11px; fill: var(--viz-muted-fg); text-anchor: middle; dominant-baseline: central; pointer-events: none; }
</style>
</head>
<body>
<svg id="t" width="100%"></svg>
<script>
  const data={id:'app',label:'my-app',ch:[
    {id:'react',label:'react',ch:[{id:'react-dom',label:'react-dom',ch:[]},{id:'scheduler',label:'scheduler',ch:[]}]},
    {id:'ts',label:'typescript',ch:[]},
    {id:'vite',label:'vite',ch:[{id:'esbuild',label:'esbuild',ch:[]},{id:'rollup',label:'rollup',ch:[{id:'fsevents',label:'fsevents',ch:[]}]},{id:'postcss',label:'postcss',ch:[]}]},
    {id:'tw',label:'tailwindcss',ch:[{id:'auto',label:'autoprefixer',ch:[]},{id:'nano',label:'cssnano',ch:[]}]},
  ]};
  const NW=120,NH=32,GX=36,GY=14,TR=7;
  const col=[[`var(--viz-chart-1)`,`var(--viz-chart-1)`],[`var(--viz-chart-2)`,`var(--viz-chart-2)`],[`var(--viz-chart-3)`,`var(--viz-chart-3)`],[`var(--viz-chart-4)`,`var(--viz-chart-4)`]];
  const collapsed=new Set();
  const svg=document.getElementById('t');

  function layout(node,d,y){
    const items=[{...node,d,y,x:d*(NW+GX)+NW/2+16,hc:node.ch.length>0}];
    if(!collapsed.has(node.id)&&node.ch.length>0){let cy=y;node.ch.forEach(c=>{const ci=layout(c,d+1,cy);items.push(...ci);cy=Math.max(...ci.map(n=>n.y))+NH+GY;});}
    return items;
  }
  function findNode(n,id){if(n.id===id)return n;for(const c of n.ch){const f=findNode(c,id);if(f)return f;}return null;}
  function center(node,flat){
    if(collapsed.has(node.id)||!node.ch.length)return;
    node.ch.forEach(c=>center(c,flat));
    const p=flat.find(f=>f.id===node.id),ci=node.ch.map(c=>flat.find(f=>f.id===c.id)).filter(Boolean);
    if(p&&ci.length)p.y=(Math.min(...ci.map(c=>c.y))+Math.max(...ci.map(c=>c.y)))/2;
  }
  function render(){
    const flat=layout(data,0,16);center(data,flat);
    const mxX=Math.max(...flat.map(n=>n.x))+NW/2+20,mxY=Math.max(...flat.map(n=>n.y))+NH+16;
    svg.setAttribute('viewBox',`0 0 ${mxX} ${mxY}`);
    let h='';
    flat.forEach(n=>{if(n.d===0)return;const orig=findNode(data,n.id);flat.forEach(p=>{if(p.d!==n.d-1)return;const pn=findNode(data,p.id);if(!pn||!pn.ch.some(c=>c.id===n.id))return;const x1=p.x+NW/2,y1=p.y+NH/2,x2=n.x-NW/2,y2=n.y+NH/2,mx=(x1+x2)/2;h+=`<path class="edge" d="M${x1} ${y1}C${mx} ${y1},${mx} ${y2},${x2} ${y2}"/>`;});});
    const c=col;flat.forEach(n=>{const rx=n.x-NW/2,ry=n.y,ci=Math.min(n.d,c.length-1);h+=`<rect class="nr" data-viz="node" x="${rx}" y="${ry}" width="${NW}" height="${NH}" rx="8" fill="${c[ci][0]}" stroke="${c[ci][1]}"/>`;h+=`<text class="nl" x="${n.x}" y="${ry+NH/2}">${n.label}</text>`;if(n.hc){const tx=rx+NW+4,ty=ry+NH/2;h+=`<circle class="tog" cx="${tx}" cy="${ty}" r="${TR}" data-t="${n.id}"/><text class="ti" x="${tx}" y="${ty}">${collapsed.has(n.id)?'+':'\u2212'}</text>`;}});
    svg.innerHTML=h;
  }
  svg.addEventListener('click',e=>{const t=e.target.closest('[data-t]');if(!t)return;const id=t.getAttribute('data-t');collapsed.has(id)?collapsed.delete(id):collapsed.add(id);render();});
  render();
</script>
</body>
</html>
