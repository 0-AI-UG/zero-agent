<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Line Chart</title>
<style>
  :root { --bg: #fff; --text: #2c2c2a; --text-t: #888780; --border: rgba(0,0,0,0.12); }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: var(--bg); color: var(--text); }
  svg { display: block; }
  .pt { cursor: pointer; transition: r 0.15s; }
  .pt:hover { r: 6; }
  .lbl { font-size: 11px; fill: var(--text-t); text-anchor: middle; }
  .legend { display: flex; gap: 12px; padding: 8px 12px; font-size: 11px; color: var(--text-t); }
  .legend-line { width: 12px; height: 2px; display: inline-block; margin-right: 4px; vertical-align: middle; }
</style>
</head>
<body>
<svg id="c" width="100%" viewBox="0 0 680 300"></svg>
<div class="legend" id="leg"></div>
<script>
  const data = {
    labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug'],
    series: [
      { name: 'This Year', color: '#534AB7', values: [30,45,38,62,55,78,70,85] },
      { name: 'Last Year', color: '#0F6E56', values: [20,32,28,45,40,55,50,60] },
    ],
  };
  const svg = document.getElementById('c');
  const P = { t: 20, r: 16, b: 28, l: 40 }, W = 680, H = 300;
  const pW = W - P.l - P.r, pH = H - P.t - P.b;
  const max = Math.max(...data.series.flatMap(s => s.values));
  const n = data.labels.length;
  const x = i => P.l + (i / (n - 1)) * pW;
  const y = v => P.t + pH - (v / max) * pH;

  // Grid
  for (let i = 0; i <= 4; i++) {
    const yy = P.t + pH - (pH / 4) * i;
    const v = Math.round((max / 4) * i);
    svg.innerHTML += `<line x1="${P.l}" x2="${W-P.r}" y1="${yy}" y2="${yy}" stroke="var(--border)" stroke-width="0.5"/>`;
    svg.innerHTML += `<text class="lbl" x="${P.l-6}" y="${yy+4}" text-anchor="end">${v}</text>`;
  }
  data.labels.forEach((l, i) => { svg.innerHTML += `<text class="lbl" x="${x(i)}" y="${H-8}">${l}</text>`; });

  data.series.forEach(s => {
    const pts = s.values.map((v, i) => `${x(i)},${y(v)}`).join(' ');
    svg.innerHTML += `<polyline points="${pts}" fill="none" stroke="${s.color}" stroke-width="2" stroke-linejoin="round"/>`;
    s.values.forEach((v, i) => { svg.innerHTML += `<circle class="pt" cx="${x(i)}" cy="${y(v)}" r="4" fill="${s.color}" aria-label="${s.name} ${data.labels[i]}: ${v}"><title>${s.name} ${data.labels[i]}: ${v}</title></circle>`; });
  });

  data.series.forEach(s => {
    document.getElementById('leg').innerHTML += `<span><span class="legend-line" style="background:${s.color}"></span>${s.name}</span>`;
  });
</script>
</body>
</html>
