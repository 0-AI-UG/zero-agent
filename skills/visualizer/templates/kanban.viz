<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kanban Board</title>
<style>
  :root {
    --bg: #ffffff;
    --bg-secondary: #f8f7f5;
    --bg-tertiary: #f1efe8;
    --text: #2c2c2a;
    --text-secondary: #5f5e5a;
    --text-tertiary: #888780;
    --border: rgba(0, 0, 0, 0.12);
    --border-emphasis: rgba(0, 0, 0, 0.25);
    --info: #378add;
    --success: #639922;
    --warning: #ef9f27;
    --danger: #e24b4a;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { height: 100%; overflow: hidden; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
  }
  h1 { font-size: 0.875rem; font-weight: 500; margin-bottom: 0.5rem; }
  .board {
    display: flex;
    gap: 0.75rem;
    flex: 1;
    overflow-x: auto;
    padding-bottom: 0.5rem;
  }
  .column {
    flex: 1;
    flex-shrink: 0;
    min-width: 180px;
    background: var(--bg-secondary);
    border-radius: 12px;
    padding: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    min-height: 0;
  }
  .column-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-left: 0.5rem;
    border-left: 3px solid var(--text-secondary);
  }
  .column-name {
    font-size: 0.875rem;
    font-weight: 500;
  }
  .column-count {
    font-size: 0.6875rem;
    font-weight: 500;
    background: var(--border);
    color: var(--text-secondary);
    padding: 0.0625rem 0.4375rem;
    border-radius: 9999px;
  }
  .card-list {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    flex: 1;
    min-height: 0;
    overflow-y: auto;
  }
  .card {
    background: var(--bg);
    border: 0.5px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem;
    transition: background 0.15s ease;
    opacity: 0;
    animation: cardFadeIn 0.3s ease forwards;
  }
  .card:hover {
    background: var(--bg-secondary);
  }
  .card-title {
    font-size: 0.75rem;
    font-weight: 500;
  }
  .card-desc {
    font-size: 0.6875rem;
    color: var(--text-secondary);
    margin-top: 0.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-top: 0.5rem;
  }
  .tag {
    font-size: 0.625rem;
    padding: 0.125rem 0.375rem;
    border-radius: 9999px;
    background: var(--bg-secondary);
    color: var(--text-secondary);
  }
  .tag.critical {
    background: rgba(226, 75, 74, 0.1);
    color: var(--danger);
  }
  @keyframes cardFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
</head>
<body>
  <h1>Kanban Board</h1>
  <div class="board" id="board"></div>

  <script>
    // <!-- DATA -->
    const boardData = {
      columns: [
        {
          name: "Backlog",
          color: "#5f5e5a",
          cards: [
            { title: "Research competitors", desc: "Analyze top 5 competitor features", tags: ["research"] },
            { title: "Update documentation", tags: ["docs"] },
          ],
        },
        {
          name: "In Progress",
          color: "#534AB7",
          cards: [
            { title: "Redesign dashboard", desc: "New layout with improved KPI cards", tags: ["design", "frontend"] },
            { title: "API rate limiting", desc: "Implement token bucket algorithm", tags: ["backend"] },
            { title: "User onboarding flow", tags: ["ux"] },
          ],
        },
        {
          name: "Review",
          color: "#EF9F27",
          cards: [
            { title: "Payment integration", desc: "Stripe webhook handling", tags: ["backend", "critical"] },
          ],
        },
        {
          name: "Done",
          color: "#639922",
          cards: [
            { title: "Login page redesign", tags: ["design"] },
            { title: "Database migration", desc: "Migrate to PostgreSQL 16", tags: ["backend"] },
          ],
        },
      ],
    };

    const board = document.getElementById("board");

    boardData.columns.forEach((col, colIdx) => {
      const column = document.createElement("div");
      column.className = "column";

      const header = document.createElement("div");
      header.className = "column-header";
      header.style.borderLeftColor = col.color;
      header.innerHTML = `
        <span class="column-name">${col.name}</span>
        <span class="column-count">${col.cards.length}</span>
      `;
      column.appendChild(header);

      const cardList = document.createElement("div");
      cardList.className = "card-list";

      col.cards.forEach((card, cardIdx) => {
        const el = document.createElement("div");
        el.className = "card";
        el.style.animationDelay = `${colIdx * 100 + cardIdx * 40}ms`;

        let html = `<div class="card-title">${card.title}</div>`;
        if (card.desc) {
          html += `<div class="card-desc">${card.desc}</div>`;
        }
        if (card.tags && card.tags.length) {
          html += `<div class="card-tags">${card.tags.map(t =>
            `<span class="tag${t === "critical" ? " critical" : ""}">${t}</span>`
          ).join("")}</div>`;
        }

        el.innerHTML = html;
        cardList.appendChild(el);
      });

      column.appendChild(cardList);
      board.appendChild(column);
    });
  </script>
</body>
</html>
