<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Metric Cards</title>
<style>
  :root {
    --bg: #ffffff;
    --bg-secondary: #f8f7f5;
    --bg-tertiary: #f1efe8;
    --text: #2c2c2a;
    --text-secondary: #5f5e5a;
    --text-tertiary: #888780;
    --border: rgba(0, 0, 0, 0.12);
    --border-emphasis: rgba(0, 0, 0, 0.25);
    --info: #378add;
    --success: #639922;
    --warning: #ef9f27;
    --danger: #e24b4a;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { height: 100%; overflow: hidden; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
  }
  h1 { font-size: 0.875rem; font-weight: 500; margin-bottom: 0.5rem; }

  .grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    flex: 1;
    min-height: 0;
    align-content: flex-start;
  }

  .card {
    flex: 1;
    min-width: 200px;
    background: var(--bg);
    border: 0.5px solid var(--border);
    border-radius: 12px;
    padding: 0.75rem;
    transition: background 0.15s ease;
    opacity: 0;
    animation: fadeIn 0.4s ease forwards;
  }
  .card:hover {
    background: var(--bg-secondary);
  }

  .card-label {
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
  }

  .card-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.375rem;
  }

  .card-value {
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1;
  }

  .card-change {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    font-size: 0.75rem;
    font-weight: 500;
  }
  .card-change.up { color: var(--success); }
  .card-change.down { color: var(--danger); }
  .card-change svg { width: 12px; height: 12px; flex-shrink: 0; }

  .sparkline-svg {
    display: block;
    width: 100%;
    height: 40px;
  }
  .sparkline-line {
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .sparkline-fill {
    stroke: none;
  }
  .sparkline-animate {
    animation: drawLine 1s ease forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes drawLine {
    from { stroke-dashoffset: var(--line-length); }
    to { stroke-dashoffset: 0; }
  }
</style>
</head>
<body>

<h1>Key Metrics</h1>
<div class="grid" id="grid"></div>

<script>
const metrics = [
  { label: "Total Revenue", value: "$128,430", change: "+12.5%", direction: "up", sparkline: [65, 72, 68, 80, 75, 90, 85, 95, 88, 102, 98, 115] },
  { label: "Active Users", value: "8,240", change: "+5.3%", direction: "up", sparkline: [420, 450, 440, 480, 470, 510, 500, 530, 520, 560, 540, 580] },
  { label: "Conversion Rate", value: "3.24%", change: "-0.4%", direction: "down", sparkline: [3.8, 3.6, 3.5, 3.4, 3.5, 3.3, 3.2, 3.4, 3.3, 3.1, 3.2, 3.24] },
  { label: "Avg. Order Value", value: "$67.50", change: "+2.1%", direction: "up", sparkline: [58, 60, 62, 59, 63, 61, 64, 63, 65, 64, 66, 67.5] },
];

const grid = document.getElementById("grid");

function buildSparklinePath(data, width, height) {
  const padding = 2;
  const min = Math.min(...data);
  const max = Math.max(...data);
  const range = max - min || 1;
  const stepX = (width - padding * 2) / (data.length - 1);
  const points = data.map((v, i) => {
    const x = padding + i * stepX;
    const y = padding + (1 - (v - min) / range) * (height - padding * 2);
    return `${x.toFixed(2)},${y.toFixed(2)}`;
  });
  return points.join(" ");
}

function arrowSvg(direction) {
  if (direction === "up") {
    return `<svg viewBox="0 0 12 12"><path d="M6 2.5L10 7H2L6 2.5Z" fill="currentColor"/></svg>`;
  }
  return `<svg viewBox="0 0 12 12"><path d="M6 9.5L2 5H10L6 9.5Z" fill="currentColor"/></svg>`;
}

metrics.forEach((m, i) => {
  const card = document.createElement("div");
  card.className = "card";
  card.style.animationDelay = `${i * 60}ms`;

  const lineColor = m.direction === "up" ? "var(--info)" : "var(--danger)";
  const fillColor = m.direction === "up" ? "rgba(55,138,221,0.1)" : "rgba(226,75,74,0.1)";

  const svgW = 300;
  const svgH = 40;
  const polyPoints = buildSparklinePath(m.sparkline, svgW, svgH);

  // Build the fill polygon (closes to bottom-right then bottom-left)
  const padding = 2;
  const lastX = (padding + (m.sparkline.length - 1) * ((svgW - padding * 2) / (m.sparkline.length - 1))).toFixed(2);
  const fillPoints = `${polyPoints} ${lastX},${svgH - padding} ${padding.toFixed(2)},${svgH - padding}`;

  const gradientId = `grad${i}`;

  card.innerHTML = `
    <div class="card-label">${m.label}</div>
    <div class="card-row">
      <span class="card-value">${m.value}</span>
      <span class="card-change ${m.direction}">${arrowSvg(m.direction)}${m.change}</span>
    </div>
    <svg class="sparkline-svg" viewBox="0 0 ${svgW} ${svgH}" preserveAspectRatio="none">
      <defs>
        <linearGradient id="${gradientId}" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="${m.direction === 'up' ? '#534AB7' : '#E24B4A'}" stop-opacity="0.1"/>
          <stop offset="100%" stop-color="${m.direction === 'up' ? '#534AB7' : '#E24B4A'}" stop-opacity="0"/>
        </linearGradient>
      </defs>
      <polygon class="sparkline-fill" points="${fillPoints}" fill="url(#${gradientId})"/>
      <polyline class="sparkline-line sparkline-animate" points="${polyPoints}" stroke="${lineColor}"/>
    </svg>
  `;

  grid.appendChild(card);

  // Set stroke-dasharray for draw-in animation
  requestAnimationFrame(() => {
    const line = card.querySelector(".sparkline-line");
    if (line) {
      const length = line.getTotalLength();
      line.style.strokeDasharray = length;
      line.style.strokeDashoffset = length;
      line.style.setProperty("--line-length", length);
      // Force reflow to restart animation
      void line.offsetWidth;
      line.classList.remove("sparkline-animate");
      void line.offsetWidth;
      line.classList.add("sparkline-animate");
    }
  });
});
</script>
</body>
</html>
