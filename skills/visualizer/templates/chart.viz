<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bar Chart</title>
<style>
  :root { --bg: #fff; --text: #2c2c2a; --text-t: #888780; --border: rgba(0,0,0,0.12); }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: var(--bg); color: var(--text); }
  svg { display: block; }
  .bar { transition: opacity 0.15s; cursor: pointer; }
  .bar:hover { opacity: 0.8; }
  .lbl { font-size: 11px; fill: var(--text-t); text-anchor: middle; }
  .val { font-size: 11px; fill: var(--text); text-anchor: middle; }
  .legend { display: flex; gap: 12px; padding: 8px 12px; font-size: 11px; color: var(--text-t); }
  .legend-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 4px; }
</style>
</head>
<body>
<svg id="c" width="100%" viewBox="0 0 680 300"></svg>
<div class="legend" id="leg"></div>
<script>
  const data = {
    labels: ['Jan','Feb','Mar','Apr','May','Jun'],
    series: [
      { name: 'Revenue', color: '#534AB7', values: [42,58,35,72,61,85] },
      { name: 'Expenses', color: '#0F6E56', values: [30,40,28,50,45,55] },
    ],
  };
  const svg = document.getElementById('c');
  const P = { t: 20, r: 16, b: 28, l: 16 }, W = 680, H = 300;
  const pW = W - P.l - P.r, pH = H - P.t - P.b;
  const max = Math.max(...data.series.flatMap(s => s.values));
  const n = data.labels.length, ns = data.series.length;
  const gw = pW / n, bw = (gw - 8) / ns;

  // Grid
  for (let i = 0; i <= 4; i++) {
    const y = P.t + pH - (pH / 4) * i;
    svg.innerHTML += `<line x1="${P.l}" x2="${W-P.r}" y1="${y}" y2="${y}" stroke="var(--border)" stroke-width="0.5"/>`;
  }

  data.labels.forEach((l, i) => {
    const gx = P.l + i * gw;
    data.series.forEach((s, si) => {
      const h = (s.values[i] / max) * pH;
      const x = gx + 4 + si * bw;
      const y = P.t + pH - h;
      svg.innerHTML += `<rect class="bar" x="${x}" y="${y}" width="${bw-2}" height="${h}" rx="3" fill="${s.color}" aria-label="${s.name}: ${s.values[i]}"><title>${s.name}: ${s.values[i]}</title></rect>`;
    });
    svg.innerHTML += `<text class="lbl" x="${gx + gw/2}" y="${H - 8}">${l}</text>`;
  });

  data.series.forEach(s => {
    document.getElementById('leg').innerHTML += `<span><span class="legend-dot" style="background:${s.color}"></span>${s.name}</span>`;
  });
</script>
</body>
</html>
