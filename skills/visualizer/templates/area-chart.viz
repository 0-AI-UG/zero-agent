<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Area Chart</title>
<style>
  :root {
    --bg: #ffffff;
    --bg-secondary: #f8f7f5;
    --bg-tertiary: #f1efe8;
    --text: #2c2c2a;
    --text-secondary: #5f5e5a;
    --text-tertiary: #888780;
    --border: rgba(0, 0, 0, 0.12);
    --border-emphasis: rgba(0, 0, 0, 0.25);
    --info: #378add;
    --success: #639922;
    --warning: #ef9f27;
    --danger: #e24b4a;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { height: 100%; overflow: hidden; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
  }
  h1 { font-size: 0.875rem; font-weight: 500; margin-bottom: 0.5rem; }
  .chart-container {
    background: var(--bg);
    border: 0.5px solid var(--border);
    border-radius: 12px;
    padding: 0.75rem;
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }
  .chart-area {
    position: relative;
    width: 100%;
    flex: 1;
    min-height: 0;
  }
  svg { width: 100%; height: 100%; overflow: visible; }
  .grid-line { stroke: var(--border); stroke-width: 1; }
  .axis-label { font-size: 11px; fill: var(--text-secondary); }
  .data-point {
    cursor: pointer;
    transition: r 0.15s ease;
  }
  .data-point:hover { r: 6; }
  .tooltip-overlay {
    position: absolute;
    background: var(--text);
    color: var(--bg);
    padding: 0.375rem 0.625rem;
    border-radius: 8px;
    font-size: 0.75rem;
    white-space: nowrap;
    pointer-events: none;
    z-index: 10;
    transform: translate(-50%, -100%);
    margin-top: -0.5rem;
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  .tooltip-overlay.visible { opacity: 1; }
  .tooltip-overlay::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: var(--text);
  }
  .legend {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    color: var(--text-secondary);
  }
  .legend-swatch {
    width: 1rem;
    height: 0.625rem;
    border-radius: 2px;
    opacity: 0.6;
    border-top: 2px solid;
  }
  @keyframes drawLine {
    from { stroke-dashoffset: var(--line-length); }
    to { stroke-dashoffset: 0; }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 0.15; }
  }
</style>
</head>
<body>
  <h1>Area Chart</h1>
  <div class="chart-container">
    <div class="chart-area" id="chartArea">
      <svg id="chart" role="img" aria-label="Area chart"></svg>
      <div class="tooltip-overlay" id="tooltip"></div>
    </div>
    <div class="legend" id="legend"></div>
  </div>

  <script>
    // <!-- DATA -->
    const chartData = {
      labels: ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug"],
      series: [
        { name: "Revenue", color: "#534AB7", values: [30, 45, 38, 62, 55, 78, 70, 85] },
        { name: "Expenses", color: "#0F6E56", values: [20, 32, 28, 45, 40, 55, 50, 60] },
      ],
    };

    function fmt(n) { return Number(n).toLocaleString(); }

    const svg = document.getElementById("chart");
    const tooltip = document.getElementById("tooltip");
    const legend = document.getElementById("legend");
    const ns = "http://www.w3.org/2000/svg";

    const padding = { top: 20, right: 20, bottom: 30, left: 40 };
    const rect = svg.getBoundingClientRect();
    const w = rect.width;
    const h = rect.height;
    const plotW = w - padding.left - padding.right;
    const plotH = h - padding.top - padding.bottom;

    const allValues = chartData.series.flatMap(s => s.values);
    const maxVal = Math.max(...allValues);
    const minVal = 0;
    const range = maxVal - minVal;

    function x(i) { return padding.left + (i / (chartData.labels.length - 1)) * plotW; }
    function y(v) { return padding.top + plotH - ((v - minVal) / range) * plotH; }

    const baseline = y(minVal);

    // Grid lines
    const gridSteps = 5;
    for (let i = 0; i <= gridSteps; i++) {
      const val = minVal + (range / gridSteps) * i;
      const yPos = y(val);
      const line = document.createElementNS(ns, "line");
      line.setAttribute("x1", padding.left);
      line.setAttribute("x2", w - padding.right);
      line.setAttribute("y1", yPos);
      line.setAttribute("y2", yPos);
      line.setAttribute("class", "grid-line");
      svg.appendChild(line);

      const label = document.createElementNS(ns, "text");
      label.setAttribute("x", padding.left - 8);
      label.setAttribute("y", yPos + 4);
      label.setAttribute("text-anchor", "end");
      label.setAttribute("class", "axis-label");
      label.textContent = fmt(Math.round(val));
      svg.appendChild(label);
    }

    // X-axis labels
    chartData.labels.forEach((lbl, i) => {
      const label = document.createElementNS(ns, "text");
      label.setAttribute("x", x(i));
      label.setAttribute("y", h - 5);
      label.setAttribute("text-anchor", "middle");
      label.setAttribute("class", "axis-label");
      label.textContent = lbl;
      svg.appendChild(label);
    });

    // Render series in reverse order so first series is visually on top
    const reversed = [...chartData.series].reverse();

    // Areas (filled polygons)
    reversed.forEach(series => {
      const pts = series.values.map((v, i) => `${x(i)},${y(v)}`);
      const polygonPts = [
        `${x(0)},${baseline}`,
        ...pts,
        `${x(series.values.length - 1)},${baseline}`,
      ].join(" ");

      const polygon = document.createElementNS(ns, "polygon");
      polygon.setAttribute("points", polygonPts);
      polygon.setAttribute("fill", series.color);
      polygon.setAttribute("fill-opacity", "0");
      polygon.setAttribute("stroke", "none");
      polygon.style.animation = "fadeIn 0.8s ease-out 0.3s forwards";
      svg.appendChild(polygon);
    });

    // Lines (polylines) and data points
    reversed.forEach(series => {
      const pts = series.values.map((v, i) => `${x(i)},${y(v)}`);

      // Polyline
      const polyline = document.createElementNS(ns, "polyline");
      polyline.setAttribute("points", pts.join(" "));
      polyline.setAttribute("fill", "none");
      polyline.setAttribute("stroke", series.color);
      polyline.setAttribute("stroke-width", "2");
      polyline.setAttribute("stroke-linejoin", "round");
      svg.appendChild(polyline);

      // Animate line drawing
      const totalLength = polyline.getTotalLength();
      polyline.style.strokeDasharray = totalLength;
      polyline.style.strokeDashoffset = totalLength;
      polyline.style.setProperty("--line-length", totalLength);
      polyline.style.animation = "drawLine 0.8s ease-out forwards";

      // Data points
      series.values.forEach((v, i) => {
        const circle = document.createElementNS(ns, "circle");
        circle.setAttribute("cx", x(i));
        circle.setAttribute("cy", y(v));
        circle.setAttribute("r", "4");
        circle.setAttribute("fill", series.color);
        circle.setAttribute("class", "data-point");
        circle.setAttribute("role", "graphics-symbol");
        circle.setAttribute("aria-label", `${series.name} ${chartData.labels[i]}: ${fmt(v)}`);
        circle.addEventListener("mouseenter", () => {
          tooltip.textContent = `${series.name} \u2013 ${chartData.labels[i]}: ${fmt(v)}`;
          tooltip.style.left = x(i) + "px";
          tooltip.style.top = y(v) + "px";
          tooltip.classList.add("visible");
        });
        circle.addEventListener("mouseleave", () => {
          tooltip.classList.remove("visible");
        });
        svg.appendChild(circle);
      });
    });

    // Legend (original order)
    chartData.series.forEach(series => {
      const item = document.createElement("div");
      item.className = "legend-item";
      item.innerHTML = `<div class="legend-swatch" style="background:${series.color}; border-top-color:${series.color}"></div>${series.name}`;
      legend.appendChild(item);
    });
  </script>
</body>
</html>
