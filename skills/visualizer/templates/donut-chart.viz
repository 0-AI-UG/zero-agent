<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Donut Chart</title>
<style>
  :root { --bg: #fff; --text: #2c2c2a; --text-t: #888780; }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: var(--bg); color: var(--text); }
  .wrap { display: flex; align-items: center; gap: 24px; padding: 12px; }
  .donut { position: relative; width: 160px; height: 160px; flex-shrink: 0; }
  .donut svg { width: 100%; height: 100%; }
  .seg { cursor: pointer; transition: opacity 0.15s; }
  .seg:hover { opacity: 0.8; }
  .center { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); text-align: center; }
  .center-val { font-size: 20px; font-weight: 500; }
  .center-lbl { font-size: 11px; color: var(--text-t); }
  .legend { display: flex; flex-direction: column; gap: 8px; font-size: 13px; }
  .leg-row { display: flex; align-items: center; gap: 8px; }
  .leg-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .leg-pct { color: var(--text-t); font-size: 11px; margin-left: auto; }
</style>
</head>
<body>
<div class="wrap">
  <div class="donut">
    <svg viewBox="0 0 200 200" id="d"></svg>
    <div class="center"><div class="center-val" id="tot"></div><div class="center-lbl">Total</div></div>
  </div>
  <div class="legend" id="leg"></div>
</div>
<script>
  const data = [
    { name: 'Engineering', value: 42, color: '#534AB7' },
    { name: 'Marketing', value: 28, color: '#0F6E56' },
    { name: 'Sales', value: 18, color: '#D85A30' },
    { name: 'Support', value: 12, color: '#185FA5' },
  ];
  const total = data.reduce((s, d) => s + d.value, 0);
  document.getElementById('tot').textContent = total;
  const svg = document.getElementById('d');
  const cx = 100, cy = 100, r = 70, sw = 24, circ = 2 * Math.PI * r;
  let off = 0;
  data.forEach(d => {
    const pct = d.value / total, dash = pct * circ, gap = circ - dash;
    svg.innerHTML += `<circle class="seg" cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="${d.color}" stroke-width="${sw}" stroke-dasharray="${dash} ${gap}" stroke-dashoffset="${-off}" transform="rotate(-90 ${cx} ${cy})" aria-label="${d.name}: ${d.value}"><title>${d.name}: ${d.value} (${(pct*100).toFixed(1)}%)</title></circle>`;
    off += dash;
    document.getElementById('leg').innerHTML += `<div class="leg-row"><div class="leg-dot" style="background:${d.color}"></div><span>${d.name}</span><span class="leg-pct">${(pct*100).toFixed(1)}%</span></div>`;
  });
</script>
</body>
</html>
