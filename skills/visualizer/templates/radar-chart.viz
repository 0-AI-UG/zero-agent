<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Radar Chart</title>
<style>
  :root {
    --bg: #ffffff;
    --bg-secondary: #f8f7f5;
    --bg-tertiary: #f1efe8;
    --text: #2c2c2a;
    --text-secondary: #5f5e5a;
    --text-tertiary: #888780;
    --border: rgba(0, 0, 0, 0.12);
    --border-emphasis: rgba(0, 0, 0, 0.25);
    --info: #378add;
    --success: #639922;
    --warning: #ef9f27;
    --danger: #e24b4a;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { height: 100%; overflow: hidden; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
  }
  h1 { font-size: 0.875rem; font-weight: 500; margin-bottom: 0.5rem; }
  .chart-container {
    background: var(--bg);
    border: 0.5px solid var(--border);
    border-radius: 12px;
    padding: 0.75rem;
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }
  .svg-wrapper {
    display: flex;
    justify-content: center;
    flex: 1;
    min-height: 0;
  }
  svg {
    width: 100%;
    max-width: 400px;
    max-height: 100%;
  }
  .grid-ring { fill: none; stroke: var(--border); stroke-width: 1; }
  .axis-line { stroke: var(--border); stroke-width: 1; }
  .axis-label {
    font-size: 12px;
    fill: var(--text);
    font-weight: 500;
  }
  .grid-value-label {
    font-size: 9px;
    fill: var(--text-secondary);
  }
  .series-polygon {
    stroke-width: 2;
    fill-opacity: 0.15;
    transform-origin: center;
    animation: radarIn 400ms ease forwards;
  }
  .data-point {
    r: 4;
    stroke: #fff;
    stroke-width: 1.5;
    cursor: pointer;
    transition: r 0.15s ease;
  }
  .data-point:hover { r: 6; }
  @keyframes radarIn {
    from { transform: scale(0); }
    to { transform: scale(1); }
  }
  .tooltip-box {
    position: absolute;
    background: var(--text);
    color: var(--bg);
    padding: 0.375rem 0.625rem;
    border-radius: 8px;
    font-size: 0.75rem;
    white-space: nowrap;
    pointer-events: none;
    z-index: 10;
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  .tooltip-box.visible { opacity: 1; }
  .tooltip-box::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: var(--text);
  }
  .legend {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    color: var(--text-secondary);
  }
  .legend-dot {
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 50%;
  }
</style>
</head>
<body>
  <h1>Radar Chart</h1>
  <div class="chart-container" style="position:relative;">
    <div class="svg-wrapper">
      <svg id="radar" viewBox="0 0 400 400" role="img" aria-label="Radar chart"></svg>
    </div>
    <div class="tooltip-box" id="tooltip"></div>
    <div class="legend" id="legend"></div>
  </div>

  <script>
    // <!-- DATA -->
    const chartData = {
      axes: ["Speed", "Power", "Range", "Durability", "Accuracy", "Efficiency"],
      maxValue: 100,
      series: [
        { name: "Product A", color: "#534AB7", values: [85, 70, 90, 60, 75, 80] },
        { name: "Product B", color: "#0F6E56", values: [65, 85, 55, 80, 90, 70] },
      ],
    };

    const svg = document.getElementById("radar");
    const tooltip = document.getElementById("tooltip");
    const legend = document.getElementById("legend");
    const NS = "http://www.w3.org/2000/svg";

    const cx = 200, cy = 200;
    const radius = 140;
    const levels = 5;
    const axes = chartData.axes;
    const n = axes.length;
    const angleSlice = (2 * Math.PI) / n;

    function vertexX(i, r) { return cx + r * Math.cos(angleSlice * i - Math.PI / 2); }
    function vertexY(i, r) { return cy + r * Math.sin(angleSlice * i - Math.PI / 2); }

    // Draw concentric grid rings
    for (let lvl = 1; lvl <= levels; lvl++) {
      const r = (radius / levels) * lvl;
      const points = [];
      for (let i = 0; i < n; i++) {
        points.push(`${vertexX(i, r)},${vertexY(i, r)}`);
      }
      const polygon = document.createElementNS(NS, "polygon");
      polygon.setAttribute("points", points.join(" "));
      polygon.setAttribute("class", "grid-ring");
      svg.appendChild(polygon);
    }

    // Draw axis lines
    for (let i = 0; i < n; i++) {
      const line = document.createElementNS(NS, "line");
      line.setAttribute("x1", cx);
      line.setAttribute("y1", cy);
      line.setAttribute("x2", vertexX(i, radius));
      line.setAttribute("y2", vertexY(i, radius));
      line.setAttribute("class", "axis-line");
      svg.appendChild(line);
    }

    // Grid value labels along first axis
    for (let lvl = 1; lvl <= levels; lvl++) {
      const val = (chartData.maxValue / levels) * lvl;
      const r = (radius / levels) * lvl;
      const lx = vertexX(0, r);
      const ly = vertexY(0, r);
      const text = document.createElementNS(NS, "text");
      text.setAttribute("x", lx + 4);
      text.setAttribute("y", ly - 4);
      text.setAttribute("class", "grid-value-label");
      text.textContent = val;
      svg.appendChild(text);
    }

    // Axis labels
    const labelPad = 18;
    for (let i = 0; i < n; i++) {
      const lx = vertexX(i, radius + labelPad);
      const ly = vertexY(i, radius + labelPad);
      const text = document.createElementNS(NS, "text");
      text.setAttribute("x", lx);
      text.setAttribute("y", ly);
      text.setAttribute("class", "axis-label");
      text.setAttribute("dy", "0.35em");

      const angle = angleSlice * i - Math.PI / 2;
      const cos = Math.cos(angle);
      if (Math.abs(cos) < 0.01) {
        text.setAttribute("text-anchor", "middle");
      } else if (cos < 0) {
        text.setAttribute("text-anchor", "end");
      } else {
        text.setAttribute("text-anchor", "start");
      }
      text.textContent = axes[i];
      svg.appendChild(text);
    }

    // Draw series polygons and data points
    chartData.series.forEach((series, si) => {
      const points = [];
      const coords = [];
      for (let i = 0; i < n; i++) {
        const ratio = series.values[i] / chartData.maxValue;
        const r = radius * ratio;
        const px = vertexX(i, r);
        const py = vertexY(i, r);
        points.push(`${px},${py}`);
        coords.push({ x: px, y: py, axis: axes[i], value: series.values[i] });
      }

      const polygon = document.createElementNS(NS, "polygon");
      polygon.setAttribute("points", points.join(" "));
      polygon.setAttribute("fill", series.color);
      polygon.setAttribute("stroke", series.color);
      polygon.setAttribute("class", "series-polygon");
      polygon.style.animationDelay = `${si * 100}ms`;
      polygon.style.opacity = "0";
      polygon.style.animation = `radarIn 400ms ease ${si * 100}ms forwards`;
      svg.appendChild(polygon);

      // Data point circles
      coords.forEach(pt => {
        const circle = document.createElementNS(NS, "circle");
        circle.setAttribute("cx", pt.x);
        circle.setAttribute("cy", pt.y);
        circle.setAttribute("fill", series.color);
        circle.setAttribute("class", "data-point");
        circle.setAttribute("role", "graphics-symbol");
        circle.setAttribute("aria-label", `${series.name} - ${pt.axis}: ${pt.value}`);

        circle.addEventListener("mouseenter", (e) => {
          tooltip.textContent = `${pt.axis}: ${pt.value}`;
          tooltip.classList.add("visible");
          positionTooltip(e);
        });
        circle.addEventListener("mousemove", positionTooltip);
        circle.addEventListener("mouseleave", () => {
          tooltip.classList.remove("visible");
        });
        svg.appendChild(circle);
      });
    });

    function positionTooltip(e) {
      const container = document.querySelector(".chart-container");
      const rect = container.getBoundingClientRect();
      const tx = e.clientX - rect.left;
      const ty = e.clientY - rect.top;
      tooltip.style.left = tx + "px";
      tooltip.style.top = (ty - 36) + "px";
      tooltip.style.transform = "translateX(-50%)";
    }

    // Legend
    chartData.series.forEach(series => {
      const item = document.createElement("div");
      item.className = "legend-item";
      item.innerHTML = `<div class="legend-dot" style="background:${series.color}"></div>${series.name}`;
      legend.appendChild(item);
    });
  </script>
</body>
</html>
