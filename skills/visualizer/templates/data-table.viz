<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Data Table</title>
<style>
  :root { --bg: #fff; --bg-s: #f8f7f5; --text: #2c2c2a; --text-t: #888780; --border: rgba(0,0,0,0.12); --info: #378add; }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: var(--bg); color: var(--text); padding: 12px; }
  .search { width: 100%; padding: 8px 12px; border: 0.5px solid var(--border); border-radius: 8px; font-size: 13px; margin-bottom: 8px; outline: none; }
  .search:focus { border-color: var(--info); }
  .wrap { overflow: auto; border: 0.5px solid var(--border); border-radius: 8px; }
  table { width: 100%; border-collapse: collapse; }
  th { background: var(--bg-s); padding: 8px 12px; text-align: left; font-size: 11px; font-weight: 500; color: var(--text-t); cursor: pointer; border-bottom: 0.5px solid var(--border); white-space: nowrap; }
  th:hover { color: var(--text); }
  td { padding: 8px 12px; font-size: 13px; border-bottom: 0.5px solid var(--border); }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--bg-s); }
  .count { font-size: 11px; color: var(--text-t); margin-top: 8px; }
</style>
</head>
<body>
<input type="text" class="search" id="s" placeholder="Search..." aria-label="Search">
<div class="wrap"><table><thead><tr id="hd"></tr></thead><tbody id="bd"></tbody></table></div>
<div class="count" id="ct"></div>
<script>
  const cols = ['Name','Category','Value','Status'];
  const data = [
    ['Alpha Project','Engineering','$125,000','Active'],
    ['Beta Campaign','Marketing','$45,200','Active'],
    ['Gamma Research','R&D','$89,750','Paused'],
    ['Delta Analytics','Data','$62,300','Active'],
    ['Epsilon Design','Creative','$38,900','Completed'],
    ['Zeta Platform','Engineering','$210,500','Active'],
  ];
  let sc=-1,sa=true,filtered=[...data];
  const hd=document.getElementById('hd'),bd=document.getElementById('bd');
  function render(){bd.innerHTML='';filtered.forEach(r=>{const tr=document.createElement('tr');r.forEach(c=>{const td=document.createElement('td');td.textContent=c;tr.appendChild(td);});bd.appendChild(tr);});document.getElementById('ct').textContent=filtered.length+' of '+data.length+' rows';}
  cols.forEach((c,i)=>{const th=document.createElement('th');th.textContent=c;th.onclick=()=>{if(sc===i)sa=!sa;else{sc=i;sa=true;}filtered.sort((a,b)=>{const r=a[i].localeCompare(b[i],undefined,{numeric:true});return sa?r:-r;});render();};hd.appendChild(th);});
  document.getElementById('s').addEventListener('input',e=>{const q=e.target.value.toLowerCase();filtered=data.filter(r=>r.some(c=>c.toLowerCase().includes(q)));render();});
  render();
</script>
</body>
</html>
