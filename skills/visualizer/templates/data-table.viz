<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Data Table</title>
<style>
  :root {
    --color-bg: #ffffff;
    --color-surface: #ffffff;
    --color-surface-muted: #f5f5f5;
    --color-border: #e5e5e5;
    --color-text: #1b1b1b;
    --color-text-muted: #737373;
    --color-primary: #005bd9;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { height: 100%; overflow: hidden; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    background: var(--color-bg);
    color: var(--color-text);
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
  }
  h1 { font-size: 0.875rem; font-weight: 500; margin-bottom: 0.5rem; }
  .search-bar {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 0.8125rem;
    margin-bottom: 0.5rem;
    outline: none;
  }
  .search-bar:focus { border-color: var(--color-primary); outline: 2px solid var(--color-primary); outline-offset: 2px; }
  .table-wrapper {
    overflow-x: auto;
    overflow-y: auto;
    border: 1px solid var(--color-border);
    border-radius: 0.625rem;
    flex: 1;
    min-height: 0;
  }
  table { width: 100%; border-collapse: collapse; }
  th {
    background: var(--color-surface-muted);
    padding: 0.5rem 0.75rem;
    text-align: left;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
    border-bottom: 1px solid var(--color-border);
  }
  th:hover { color: var(--color-text); }
  th .sort-indicator { margin-left: 0.25rem; }
  td {
    padding: 0.5rem 0.75rem;
    font-size: 0.8125rem;
    border-bottom: 1px solid var(--color-border);
  }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--color-surface-muted); transition: background 0.15s ease; }
  .count { font-size: 0.75rem; color: var(--color-text-muted); margin-top: 0.75rem; }
</style>
</head>
<body>
  <h1>Data Table</h1>
  <input type="text" class="search-bar" id="search" placeholder="Search..." aria-label="Search table">
  <div class="table-wrapper">
    <table id="table" role="grid" aria-label="Data table">
      <thead><tr id="header"></tr></thead>
      <tbody id="body"></tbody>
    </table>
  </div>
  <div class="count" id="count"></div>

  <script>
    // <!-- DATA -->
    const columns = ["Name", "Category", "Value", "Status"];
    const data = [
      ["Alpha Project", "Engineering", "$125,000", "Active"],
      ["Beta Campaign", "Marketing", "$45,200", "Active"],
      ["Gamma Research", "R&D", "$89,750", "Paused"],
      ["Delta Analytics", "Data", "$62,300", "Active"],
      ["Epsilon Design", "Creative", "$38,900", "Completed"],
      ["Zeta Platform", "Engineering", "$210,500", "Active"],
      ["Eta Outreach", "Marketing", "$28,400", "Paused"],
      ["Theta Testing", "QA", "$15,800", "Active"],
    ];

    let sortCol = -1;
    let sortAsc = true;
    let filtered = [...data];

    const header = document.getElementById("header");
    const body = document.getElementById("body");
    const search = document.getElementById("search");
    const count = document.getElementById("count");

    function render() {
      body.innerHTML = "";
      filtered.forEach(row => {
        const tr = document.createElement("tr");
        row.forEach(cell => {
          const td = document.createElement("td");
          td.textContent = cell;
          tr.appendChild(td);
        });
        body.appendChild(tr);
      });
      count.textContent = `${filtered.length} of ${data.length} rows`;
    }

    // Build headers
    columns.forEach((col, i) => {
      const th = document.createElement("th");
      th.innerHTML = `${col}<span class="sort-indicator"></span>`;
      th.setAttribute("role", "columnheader");
      th.setAttribute("aria-label", `Sort by ${col}`);
      th.onclick = () => {
        if (sortCol === i) { sortAsc = !sortAsc; } else { sortCol = i; sortAsc = true; }
        filtered.sort((a, b) => {
          const av = a[i], bv = b[i];
          const cmp = av.localeCompare(bv, undefined, { numeric: true });
          return sortAsc ? cmp : -cmp;
        });
        document.querySelectorAll(".sort-indicator").forEach(s => s.textContent = "");
        th.querySelector(".sort-indicator").textContent = sortAsc ? " \u25B2" : " \u25BC";
        render();
      };
      header.appendChild(th);
    });

    // Search
    search.addEventListener("input", () => {
      const q = search.value.toLowerCase();
      filtered = data.filter(row => row.some(cell => cell.toLowerCase().includes(q)));
      render();
    });

    render();
  </script>
</body>
</html>
