<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Treemap</title>
<style>
  :root {
    --bg: #ffffff;
    --bg-secondary: #f8f7f5;
    --bg-tertiary: #f1efe8;
    --text: #2c2c2a;
    --text-secondary: #5f5e5a;
    --text-tertiary: #888780;
    --border: rgba(0, 0, 0, 0.12);
    --border-emphasis: rgba(0, 0, 0, 0.25);
    --info: #378add;
    --success: #639922;
    --warning: #ef9f27;
    --danger: #e24b4a;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { height: 100%; overflow: hidden; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
  }
  h1 { font-size: 0.875rem; font-weight: 500; margin-bottom: 0.5rem; }
  .card {
    background: var(--bg);
    border: 0.5px solid var(--border);
    border-radius: 12px;
    padding: 0.75rem;
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }
  .treemap-container {
    width: 100%;
    flex: 1;
    min-height: 0;
    position: relative;
    overflow: hidden;
    border-radius: 12px;
  }
  .treemap-rect {
    position: absolute;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    cursor: pointer;
    transition: filter 0.15s ease;
    transform: scale(0);
    animation: rectAppear 0.3s ease forwards;
  }
  .treemap-rect:hover { filter: brightness(1.12); }
  .treemap-rect-inner {
    position: absolute;
    inset: 2px;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 0.375rem;
  }
  .rect-name {
    font-weight: 500;
    font-size: 0.8rem;
    color: #ffffff;
    line-height: 1.2;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
  }
  .rect-value {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.8);
    line-height: 1.2;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
  }
  .rect-label-hidden .rect-name,
  .rect-label-hidden .rect-value { display: none; }

  @keyframes rectAppear {
    to { transform: scale(1); }
  }

  .tooltip-box {
    display: none;
    position: fixed;
    background: var(--text);
    color: var(--bg);
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    font-size: 0.75rem;
    white-space: nowrap;
    pointer-events: none;
    z-index: 100;
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  .tooltip-box.visible { display: block; opacity: 1; }
  .tooltip-box::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: var(--text);
  }
  .tooltip-name { font-weight: 500; margin-bottom: 0.125rem; }
  .tooltip-detail { color: rgba(255,255,255,0.75); }
</style>
</head>
<body>
  <h1>Treemap</h1>
  <div class="card">
    <div class="treemap-container" id="treemap"></div>
  </div>
  <div class="tooltip-box" id="tooltip">
    <div class="tooltip-name" id="tooltipName"></div>
    <div class="tooltip-detail" id="tooltipDetail"></div>
  </div>

  <script>
    // <!-- DATA -->
    const chartData = {
      items: [
        { name: "Electronics", value: 45000 },
        { name: "Clothing", value: 28000 },
        { name: "Food & Beverage", value: 22000 },
        { name: "Home & Garden", value: 15000 },
        { name: "Sports", value: 12000 },
        { name: "Books", value: 8000 },
        { name: "Toys", value: 6000 },
        { name: "Health", value: 5000 },
      ],
    };

    const COLORS = ["#534AB7", "#0F6E56", "#D85A30", "#185FA5", "#639922", "#854F0B", "#E24B4A", "#378ADD"];

    function fmtCompact(n) {
      if (n >= 1e9) return (n / 1e9).toFixed(1).replace(/\.0$/, "") + "B";
      if (n >= 1e6) return (n / 1e6).toFixed(1).replace(/\.0$/, "") + "M";
      if (n >= 1e3) return (n / 1e3).toFixed(1).replace(/\.0$/, "") + "K";
      return n.toLocaleString();
    }

    function fmtPct(ratio) {
      return (ratio * 100).toFixed(1) + "%";
    }

    // Sort items descending by value
    const items = [...chartData.items].sort((a, b) => b.value - a.value);
    const total = items.reduce((s, d) => s + d.value, 0);

    // Squarified treemap layout using slice-and-dice
    function layoutTreemap(items, x, y, w, h, vertical) {
      if (items.length === 0) return [];
      if (items.length === 1) {
        return [{ item: items[0], x, y, w, h }];
      }

      const totalVal = items.reduce((s, d) => s + d.value, 0);
      const rects = [];

      // Find best split point using squarify heuristic
      let bestSplit = 1;
      let bestAspect = Infinity;

      for (let i = 1; i < items.length; i++) {
        const leftVal = items.slice(0, i).reduce((s, d) => s + d.value, 0);
        const leftRatio = leftVal / totalVal;
        const rightRatio = 1 - leftRatio;

        let leftW, leftH, rightW, rightH;
        if (vertical) {
          leftW = w * leftRatio; leftH = h;
          rightW = w * rightRatio; rightH = h;
        } else {
          leftW = w; leftH = h * leftRatio;
          rightW = w; rightH = h * rightRatio;
        }

        // Compute worst aspect ratio in both halves
        const leftAspect = Math.max(leftW / leftH, leftH / leftW);
        const rightAspect = Math.max(rightW / rightH, rightH / rightW);
        const worstAspect = Math.max(leftAspect, rightAspect);

        if (worstAspect < bestAspect) {
          bestAspect = worstAspect;
          bestSplit = i;
        }
      }

      const leftItems = items.slice(0, bestSplit);
      const rightItems = items.slice(bestSplit);
      const leftVal = leftItems.reduce((s, d) => s + d.value, 0);
      const leftRatio = leftVal / totalVal;

      if (vertical) {
        const splitX = x + w * leftRatio;
        rects.push(...layoutTreemap(leftItems, x, y, w * leftRatio, h, !vertical));
        rects.push(...layoutTreemap(rightItems, splitX, y, w * (1 - leftRatio), h, !vertical));
      } else {
        const splitY = y + h * leftRatio;
        rects.push(...layoutTreemap(leftItems, x, y, w, h * leftRatio, !vertical));
        rects.push(...layoutTreemap(rightItems, x, splitY, w, h * (1 - leftRatio), !vertical));
      }

      return rects;
    }

    const container = document.getElementById("treemap");
    const tooltip = document.getElementById("tooltip");
    const tooltipName = document.getElementById("tooltipName");
    const tooltipDetail = document.getElementById("tooltipDetail");

    const rects = layoutTreemap(items, 0, 0, 100, 100, true);

    rects.forEach((r, i) => {
      const colorIndex = items.indexOf(r.item) % COLORS.length;
      const pct = r.item.value / total;

      const el = document.createElement("div");
      el.className = "treemap-rect";
      el.style.left = r.x + "%";
      el.style.top = r.y + "%";
      el.style.width = r.w + "%";
      el.style.height = r.h + "%";
      el.style.animationDelay = (i * 50) + "ms";

      const inner = document.createElement("div");
      inner.className = "treemap-rect-inner";
      inner.style.background = COLORS[colorIndex];

      const nameEl = document.createElement("div");
      nameEl.className = "rect-name";
      nameEl.textContent = r.item.name;

      const valEl = document.createElement("div");
      valEl.className = "rect-value";
      valEl.textContent = fmtCompact(r.item.value);

      inner.appendChild(nameEl);
      inner.appendChild(valEl);
      el.appendChild(inner);
      container.appendChild(el);

      // Hide labels if rectangle is too small
      const checkSize = () => {
        const rect = el.getBoundingClientRect();
        if (rect.width < 60 || rect.height < 40) {
          inner.classList.add("rect-label-hidden");
        } else {
          inner.classList.remove("rect-label-hidden");
        }
      };
      requestAnimationFrame(checkSize);
      window.addEventListener("resize", checkSize);

      // Tooltip
      el.addEventListener("mouseenter", (e) => {
        tooltipName.textContent = r.item.name;
        tooltipDetail.textContent = `${fmtCompact(r.item.value)} · ${fmtPct(pct)}`;
        tooltip.classList.add("visible");
        positionTooltip(e);
      });
      el.addEventListener("mousemove", positionTooltip);
      el.addEventListener("mouseleave", () => {
        tooltip.classList.remove("visible");
      });
    });

    function positionTooltip(e) {
      const tw = tooltip.offsetWidth;
      const th = tooltip.offsetHeight;
      tooltip.style.left = (e.clientX - tw / 2) + "px";
      tooltip.style.top = (e.clientY - th - 12) + "px";
    }
  </script>
</body>
</html>
