<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Heatmap</title>
<style>
  :root {
    --bg: #ffffff;
    --bg-secondary: #f8f7f5;
    --bg-tertiary: #f1efe8;
    --text: #2c2c2a;
    --text-secondary: #5f5e5a;
    --text-tertiary: #888780;
    --border: rgba(0, 0, 0, 0.12);
    --border-emphasis: rgba(0, 0, 0, 0.25);
    --info: #378add;
    --success: #639922;
    --warning: #ef9f27;
    --danger: #e24b4a;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { height: 100%; overflow: hidden; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
  }
  h1 { font-size: 0.875rem; font-weight: 500; margin-bottom: 0.5rem; }
  .card {
    background: var(--bg);
    border: 0.5px solid var(--border);
    border-radius: 12px;
    padding: 0.75rem;
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }
  .heatmap-grid {
    display: grid;
    gap: 2px;
    width: 100%;
  }
  .col-header {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-align: center;
    padding-bottom: 0.25rem;
  }
  .row-header {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 0.5rem;
    white-space: nowrap;
  }
  .cell {
    border-radius: 8px;
    min-height: 2rem;
    cursor: pointer;
    position: relative;
    opacity: 0;
    animation: fadeIn 0.3s ease forwards;
  }
  @keyframes fadeIn {
    to { opacity: 1; }
  }
  .tooltip {
    position: fixed;
    pointer-events: none;
    background: var(--text);
    color: var(--bg);
    font-size: 0.75rem;
    line-height: 1.4;
    padding: 0.4rem 0.6rem;
    border-radius: 8px;
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.15s ease;
    z-index: 100;
  }
  .tooltip.visible { opacity: 1; }
  .tooltip::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: var(--text);
  }
  .legend {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    font-size: 0.75rem;
    color: var(--text-secondary);
  }
  .legend-bar {
    flex: 1;
    max-width: 12rem;
    height: 0.625rem;
    border-radius: 8px;
    background: linear-gradient(to right, #EEEDFE, #534AB7);
  }
</style>
</head>
<body>

<div class="card">
  <h1 id="title"></h1>
  <div class="heatmap-grid" id="grid"></div>
  <div class="legend">
    <span id="legend-min"></span>
    <div class="legend-bar"></div>
    <span id="legend-max"></span>
  </div>
</div>
<div class="tooltip" id="tooltip"></div>

<script>
const chartData = {
  title: "Weekly Activity",
  rows: ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"],
  cols: ["9am", "10am", "11am", "12pm", "1pm", "2pm", "3pm", "4pm", "5pm"],
  values: [
    [3, 7, 12, 8, 5, 9, 14, 10, 4],
    [5, 10, 15, 11, 8, 12, 18, 13, 6],
    [2, 5, 8, 6, 4, 7, 10, 8, 3],
    [8, 14, 20, 15, 10, 16, 22, 17, 9],
    [6, 11, 16, 12, 7, 13, 19, 14, 7],
    [1, 3, 4, 3, 2, 3, 5, 3, 1],
    [0, 1, 2, 1, 1, 1, 2, 1, 0],
  ],
};

(function render() {
  const { title, rows, cols, values } = chartData;
  const flat = values.flat();
  const minVal = Math.min(...flat);
  const maxVal = Math.max(...flat);
  const range = maxVal - minVal || 1;

  document.getElementById("title").textContent = title;
  document.getElementById("legend-min").textContent = minVal;
  document.getElementById("legend-max").textContent = maxVal;

  const grid = document.getElementById("grid");
  const numCols = cols.length;
  grid.style.gridTemplateColumns = "auto " + "1fr ".repeat(numCols).trim();

  // Top-left empty corner
  const corner = document.createElement("div");
  grid.appendChild(corner);

  // Column headers
  cols.forEach(function(c) {
    const el = document.createElement("div");
    el.className = "col-header";
    el.textContent = c;
    grid.appendChild(el);
  });

  // Rows
  rows.forEach(function(row, ri) {
    const rh = document.createElement("div");
    rh.className = "row-header";
    rh.textContent = row;
    grid.appendChild(rh);

    cols.forEach(function(col, ci) {
      const val = values[ri][ci];
      const t = (val - minVal) / range;
      // Interpolate from #EEEDFE (purple-50) to #534AB7 (purple-600)
      const r0 = 238, g0 = 237, b0 = 254;
      const r1 = 83, g1 = 74, b1 = 183;
      const r = Math.round(r0 + t * (r1 - r0));
      const g = Math.round(g0 + t * (g1 - g0));
      const b = Math.round(b0 + t * (b1 - b0));
      const cell = document.createElement("div");
      cell.className = "cell";
      cell.style.background = "rgb(" + r + ", " + g + ", " + b + ")";
      cell.style.animationDelay = (ri * 0.06 + ci * 0.015) + "s";
      cell.dataset.row = row;
      cell.dataset.col = col;
      cell.dataset.val = val;
      grid.appendChild(cell);
    });
  });

  // Tooltip
  var tooltip = document.getElementById("tooltip");
  grid.addEventListener("mouseover", function(e) {
    var cell = e.target.closest(".cell");
    if (!cell) return;
    tooltip.innerHTML = "<strong>" + cell.dataset.row + " &middot; " + cell.dataset.col + "</strong><br>Value: " + cell.dataset.val;
    tooltip.classList.add("visible");
    positionTooltip(cell);
  });
  grid.addEventListener("mouseout", function(e) {
    if (e.target.closest(".cell")) {
      tooltip.classList.remove("visible");
    }
  });

  function positionTooltip(cell) {
    var rect = cell.getBoundingClientRect();
    var tt = tooltip;
    tt.style.left = (rect.left + rect.width / 2) + "px";
    tt.style.top = (rect.top - 8) + "px";
    tt.style.transform = "translate(-50%, -100%)";
  }
})();
</script>
</body>
</html>
