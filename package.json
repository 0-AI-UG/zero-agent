{
  "name": "zero-agent",
  "private": true,
  "type": "module",
  "workspaces": [
    "web",
    "zero"
  ],
  "scripts": {
    "dev": "tsx dev.ts",
    "build": "bun --filter web build",
    "compile": "tsx build.ts",
    "start": "NODE_ENV=production node --max-old-space-size=1024 --trace-gc --heapsnapshot-near-heap-limit=2 --import tsx/esm server/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
